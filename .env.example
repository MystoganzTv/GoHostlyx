# Core app
NEXTAUTH_URL=https://gohostlyx.vercel.app
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# Auth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Sign-in/sign-up allowlist (comma-separated). Leave empty for OPEN public
# registration. ADMIN_EMAILS is still read as a fallback for compatibility.
ALLOWED_EMAILS=
ADMIN_EMAILS=

# Database
DATABASE_URL=
# Optional TLS hardening for production Postgres:
#   DATABASE_CA_CERT   - PEM contents of the provider CA (enables full validation)
#   DATABASE_SSL_INSECURE=true - disable cert validation ONLY if the connection
#                                fails without it (MITM risk; last resort)
DATABASE_CA_CERT=
DATABASE_SSL_INSECURE=

# Rate limiting (Upstash Redis REST). If unset, falls back to in-memory
# per-instance limiting (fine for local dev, weak on serverless).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PORTFOLIO=

# Email verification and contact form
RESEND_API_KEY=
AUTH_VERIFICATION_FROM_EMAIL=GoHostlyx <onboarding@resend.dev>
CONTACT_FORM_TO_EMAIL=hello@gohostlyx.com
CONTACT_FORM_FROM_EMAIL=GoHostlyx <onboarding@resend.dev>
